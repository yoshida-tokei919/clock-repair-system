generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 1. User & Customer Management
model Admin {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("admin")
  createdAt    DateTime @default(now())
}

model Customer {
  id           Int      @id @default(autoincrement())
  type         String   // 'individual', 'business'
  rank         Int      @default(1) // 1 to 5
  name         String
  kana         String?
  companyName  String?
  zipCode      String?
  address      String?
  phone        String?
  email        String?
  lineId       String?
  passwordHash String?
  createdAt    DateTime @default(now())
  
  // Partner Extensions
  isPartner    Boolean  @default(false)
  prefix       String?  // e.g. "T", "JK"
  currentSeq   Int      @default(0) // Last issued sequence (e.g. 100)
  
  // Document Sequences
  seqEstimate  Int      @default(0)
  seqDelivery  Int      @default(0)
  seqInvoice   Int      @default(0)
  seqWarranty  Int      @default(0)

  watches           Watch[]
  repairs           Repair[]
  deliveryNotes     DeliveryNote[]
  invoices          Invoice[]
  estimateDocuments EstimateDocument[]
  warranties        Warranty[]
}

// 2. Watch Metadata (Smart Input)
model Brand {
  id          Int       @id @default(autoincrement())
  name        String    @unique // Legacy support (Internal ID or English)
  nameEn      String?   @map("name_en") // English (e.g. ROLEX)
  nameJp      String    @map("name_jp") // Japanese (e.g. ロレックス)
  kana        String?
  initialChar String?
  
  models      Model[]
  calibers    Caliber[]
  watches     Watch[]
  // PartsMaster への複数FK対応：named relation
  parts              PartsMaster[] @relation("PartsBrand")
  movementMakerParts PartsMaster[] @relation("PartsMovementMaker")
  baseMakerParts     PartsMaster[] @relation("PartsBaseMaker")
}

model Model {
  id        Int     @id @default(autoincrement())
  brandId   Int
  name      String  // Legacy
  nameEn    String? @map("name_en")
  nameJp    String  @map("name_jp")
  
  brand     Brand   @relation(fields: [brandId], references: [id])
  references WatchReference[]
  watches   Watch[]
  parts     PartsMaster[]
}

model WatchReference {
  id        Int      @id @default(autoincrement())
  modelId   Int
  name      String   // e.g. 16233
  caliberId Int?
  
  model     Model    @relation(fields: [modelId], references: [id])
  caliber   Caliber? @relation(fields: [caliberId], references: [id])
  watches   Watch[]
}

model Caliber {
  id                  Int     @id @default(autoincrement())
  brandId             Int?
  name                String
  nameEn              String? @map("name_en")
  nameJp              String? @map("name_jp")
  movementType        String? // 'quartz', 'mechanical_simple', 'mechanical_chrono'
  standardWorkMinutes Int     @default(60)
  
  brand      Brand?  @relation(fields: [brandId], references: [id])
  references WatchReference[]
  watches    Watch[]
  // PartsMaster への複数FK対応：named relation
  parts            PartsMaster[] @relation("PartsCaliber")
  baseCaliberParts PartsMaster[] @relation("PartsBaseCaliber")
}

// 3. Repair & Watch
model Watch {
  id           Int      @id @default(autoincrement())
  brandId      Int
  modelId      Int
  referenceId  Int?
  caliberId    Int?
  serialNumber String? // Optional for vintage/unknown
  customerId   Int
  
  brand       Brand    @relation(fields: [brandId], references: [id])
  model       Model    @relation(fields: [modelId], references: [id])
  reference   WatchReference? @relation(fields: [referenceId], references: [id])
  caliber     Caliber? @relation(fields: [caliberId], references: [id])
  customer    Customer @relation(fields: [customerId], references: [id])
  repairs     Repair[]

  accessories  String?  // JSON or comma-separated list of accessories (Box, Warranty, etc.)
  
  // Fast Search Indexes
  @@index([brandId, serialNumber]) // Replaced unique constraint with index
  @@index([serialNumber])
  @@index([brandId, modelId])
}

model Repair {
  id                   Int       @id @default(autoincrement())
  uuid                 String    @unique @default(uuid())
  inquiryNumber        String    @unique // T-001
  customerId           Int
  watchId              Int
  partnerRef           String?   // Manual Partner Mgmt No
  accessories          String?   // JSON or CSV of checked items
  
  receptionDate        DateTime  @default(now())
  status               String    // 'reception', 'diagnosing', etc.
  approvalStatus       String    @default("pending")
  approvalDate         DateTime?
  
  // Scheduling & Priority Logic
  priorityScore        Int       @default(0)
  scheduledDate        DateTime?
  estimatedWorkMinutes Int       @default(0)
  
  workSummary          String?
  internalNotes        String?
  customerNote         String?
  // SEO Flags
  isPublicB2C          Boolean   @default(false)
  isPublicB2B          Boolean   @default(false)
  publicTitle          String?
  publicDescription    String?
  endUserName          String?   // B2B End User Name
  
  
  deliveryDateExpected DateTime?
  deliveryDateActual   DateTime?
  
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  customer Customer          @relation(fields: [customerId], references: [id])
  watch    Watch             @relation(fields: [watchId], references: [id])
  logs          RepairStatusLog[]
  photos        RepairPhoto[]
  estimate      Estimate?
  orderRequests OrderRequest[]
  
  deliveryNoteId Int?
  deliveryNote   DeliveryNote? @relation(fields: [deliveryNoteId], references: [id])

  invoiceId      Int?
  invoice        Invoice?      @relation(fields: [invoiceId], references: [id])

  estimateDocumentId Int?
  estimateDocument   EstimateDocument? @relation(fields: [estimateDocumentId], references: [id])

  warrantyId Int?
  warranty   Warranty? @relation(fields: [warrantyId], references: [id])
}

model RepairStatusLog {
  id        Int      @id @default(autoincrement())
  repairId  Int
  status    String
  changedAt DateTime @default(now())
  changedBy Int?     // Admin ID
  
  repair    Repair   @relation(fields: [repairId], references: [id])
}

// 4. Photos
model RepairPhoto {
  id         Int      @id @default(autoincrement())
  repairId   Int
  category   String
  storageKey String
  fileName   String?
  mimeType   String?
  createdAt  DateTime @default(now())
  
  repair     Repair   @relation(fields: [repairId], references: [id])
}

// 5. Accounting
model PricingRule {
  id                Int     @id @default(autoincrement())
  brandId           Int?
  modelId           Int?
  caliberId         Int?
  customerType      String?
  minPrice          Int
  maxPrice          Int
  suggestedWorkName String
  notes             String?
}

model Estimate {
  id             Int      @id @default(autoincrement())
  repairId       Int      @unique
  version        Int      @default(1)
  issuedDate     DateTime @default(now())
  
  technicalFee   Int      @default(0)
  mechanicCost   Int      @default(0)
  partsTotal     Int      @default(0)
  discountAmount Int      @default(0)
  shipping       Int      @default(0)
  taxAmount      Int      @default(0)
  totalAmount    Int      @default(0)
  isActive       Boolean  @default(true)
  
  repair         Repair         @relation(fields: [repairId], references: [id])
  items          EstimateItem[]
}

model EstimateItem {
  id         Int    @id @default(autoincrement())
  estimateId Int
  itemName   String
  quantity   Int    @default(1)
  unitPrice  Int
  type       String // 'part', 'labor'
  
  // For Parts Management (Phase 3)
  orderStatus String?  @default("pending") // 'pending', 'ordered', 'received'
  orderedAt   DateTime?
  
  partsMasterId Int?
  partsMaster   PartsMaster? @relation(fields: [partsMasterId], references: [id])

  createdAt   DateTime @default(now())

  estimate   Estimate @relation(fields: [estimateId], references: [id])
}

// 6. Parts

// §13 購入店マスタ
model Supplier {
  id       Int     @id @default(autoincrement())
  name     String  @unique
  url      String?
  isOnline Boolean @default(true) // true: オンライン店 / false: 実店舗
  notes    String?

  parts         PartsMaster[]
  orderRequests OrderRequest[]
}

// §13 部品マスタ（内装・外装統合）
model PartsMaster {
  id              Int     @id @default(autoincrement())

  // ── 区分 ──────────────────────────────────
  partType        String? // 'interior'（内装）| 'exterior'（外装）/ nullable for existing rows
  category        String  // 'internal', 'external', 'generic'（既存互換）
  subcategory     String? // 内装サブカテゴリ: '地板/受け'|'輪列'|'巻上'|'調速'|'裏まわり'

  // ── 外装：時計情報 ────────────────────────
  brandId         Int?
  modelId         Int?
  watchRefs       String? // 対応Ref（カンマ区切り）

  // ── 内装：ムーブメント情報 ─────────────────
  caliberId       Int?    // Cal.
  baseCaliberId   Int?    // ベースムーブメントCal.
  movementMakerId Int?    // ムーブメント製造元（brandIdと異なる場合）
  baseMakerId     Int?    // ベースムーブメント製造元

  // ── 部品情報 ──────────────────────────────
  name            String  // Legacy
  nameEn          String? @map("name_en")
  nameJp          String  @map("name_jp")
  partRefs        String? // 部品Ref（カンマ区切り複数対応）
  cousinsNumber   String? // cousins番号
  grade           String? // '純正' | 'FIT' | '合わせ'
  size            String? // サイズ（外装用・カテゴリごとテンプレ）
  photoKey        String? // 画像キー

  // ── 備考 ──────────────────────────────────
  notes1          String? @map("notes") // 備考1（既存DBカラム名保持）
  notes2          String? // 備考2

  // ── 価格情報 ──────────────────────────────
  costCurrency    String  @default("JPY") // ¥ / £ / $ / €
  costOriginal    Float   @default(0)     // 外貨建て仕入原価
  latestCostYen   Int     @default(0)     // 円換算仕入価格
  markupRate      Float   @default(1.3)   // 掛け率 1.1〜2.0
  retailPrice     Int     @default(0)     // 上代（500円単位切り上げ）

  // ── 在庫情報 ──────────────────────────────
  stockQuantity        Int     @default(0)
  minStockAlert        Int     @default(0)     // 最小在庫数アラートしきい値
  minStockAlertEnabled Boolean @default(false) // アラートON/OFF
  location             String? // 保管場所（例：A-3-2）
  supplierId           Int?    // FK → Supplier

  // ── Relations ────────────────────────────
  brand         Brand?    @relation("PartsBrand",         fields: [brandId],         references: [id])
  model         Model?    @relation(                      fields: [modelId],          references: [id])
  caliber       Caliber?  @relation("PartsCaliber",       fields: [caliberId],        references: [id])
  baseCaliber   Caliber?  @relation("PartsBaseCaliber",   fields: [baseCaliberId],    references: [id])
  movementMaker Brand?    @relation("PartsMovementMaker", fields: [movementMakerId],  references: [id])
  baseMaker     Brand?    @relation("PartsBaseMaker",     fields: [baseMakerId],      references: [id])
  supplier      Supplier? @relation(                      fields: [supplierId],        references: [id])
  orderRequests OrderRequest[]
  estimateItems EstimateItem[]
}

// 7. Documents (Bulk Generation)
model DeliveryNote {
  id           Int      @id @default(autoincrement())
  slipNumber   String   @unique // e.g. TD-001
  issuedDate   DateTime @default(now())
  
  customerId   Int
  customer     Customer @relation(fields: [customerId], references: [id])
  
  repairs      Repair[]
  
  totalAmount  Int      @default(0) // Cache for speed
  taxAmount    Int      @default(0)
}

model Invoice {
  id            Int      @id @default(autoincrement())
  invoiceNumber String   @unique // e.g. TI-001
  issuedDate    DateTime @default(now())
  
  customerId    Int
  customer      Customer @relation(fields: [customerId], references: [id])
  
  repairs       Repair[]
  
  totalAmount   Int      @default(0)
  taxAmount     Int      @default(0)
  status        String   @default("issued") // issued, paid
  paymentDueDate DateTime?
}



model EstimateDocument {
  id              Int      @id @default(autoincrement())
  estimateNumber  String   @unique // e.g. TE-001
  issuedDate      DateTime @default(now())
  
  customerId      Int
  customer        Customer @relation(fields: [customerId], references: [id])

  repairs         Repair[]

  totalAmount     Int      @default(0)
  taxAmount       Int      @default(0)
}

model Warranty {
  id              Int      @id @default(autoincrement())
  warrantyNumber  String   @unique // e.g. TW-001
  issuedDate      DateTime @default(now())
  guaranteeStart  DateTime
  guaranteeEnd    DateTime

  customerId      Int
  customer        Customer @relation(fields: [customerId], references: [id])

  repairs         Repair[]
}

// §21 発注リスト
model OrderRequest {
  id            Int      @id @default(autoincrement())

  // 部品情報
  partsMasterId Int?
  partsMaster   PartsMaster? @relation(fields: [partsMasterId], references: [id])
  partNameJp    String
  partNameEn    String?
  partRefs      String?
  cousinsNumber String?

  // 発注情報
  quantity      Int      @default(1)
  supplierId    Int?
  supplier      Supplier? @relation(fields: [supplierId], references: [id])

  // ステータス
  // pending（未発注）/ ordered（注文済み）/ received（入荷済み）/ cancelled（キャンセル）
  status        String   @default("pending")

  // 検索ワード（自動生成）
  searchWordJp  String?
  searchWordEn  String?

  // 関連カルテ
  repairId      Int?
  repair        Repair?  @relation(fields: [repairId], references: [id])

  // メモ・日時
  notes         String?
  orderedAt     DateTime?
  receivedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
